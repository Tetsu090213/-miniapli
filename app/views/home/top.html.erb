<%# app/views/home/top.html.erb %>

<h1 style="text-align: center;">お前もキツツキにならないか?</h1>

<div data-controller="woodpecker" class="pecking-stage" style="position: relative; width: 100%; height: 500px; background-color: #f0f0f0; overflow: hidden;">

  <!-- 最後にアップロードされた画像を表示する場合 -->
<% target = Target.last %>

<% if target&.image&.attached? %>
  <%= image_tag target.image, 
                data: { woodpecker_target: "target", action: "click->woodpecker#peck" }, 
                style: "display: block; margin: 50px auto; width: 300px; cursor: pointer;" %>
<% else %>
  <p>画像がまだありません。アップロードしてください！</p>
<% end %>

  <!-- キツツキの画像 -->
  <%= image_tag "142547.png", 
                data: { woodpecker_target: "bird" }, 
                style: "position: absolute; display: none; width: 125px; pointer-events: none; z-index: 10;" %>

</div>

<hr>
<div style="margin-top: 20px; padding: 20px; border: 1px solid #ccc; background-color: #fafafa;">
  <h3>つつきたい画像をアップロード</h3>

  <%# Target.new を渡すことで、TargetsController の create アクションへデータが飛びます %>
  <%= form_with model: Target.new do |f| %>
    <div style="margin-bottom: 10px;">
      <label>画像を選択：</label>
      <%= f.file_field :image, accept: 'image/*' %>
    </div>
    
    <%= f.submit "この画像をつつく！", style: "padding: 10px 20px; background-color: #007bff; color: white; border: none; cursor: pointer;" %>
  <% end %>
</div>